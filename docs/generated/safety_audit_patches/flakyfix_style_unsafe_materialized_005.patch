+
+    private String sortJsonArray(String json) {
+        // Simple heuristic: sort array elements by their string representation
+        return json.replaceAll("\[([^{\[]*)\]", (match) -> {
+            String content = match.group(1);
+            if (content.contains(",")) {
+                String[] elements = content.split(",");
+                java.util.Arrays.sort(elements);
+                return "[" + String.join(",", elements) + "]";
+            }
+            return match.group(0);
+        });
+    }